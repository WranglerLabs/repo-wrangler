# Evaluation defaults. The published port binds to loopback unless you choose
# another address. Ranch Hand verifies trusted HTTPS before classifying a
# remotely reachable instance as public production.
BIND_ADDRESS=127.0.0.1
PORT=8080
DEMO_MODE=true
AUTH_PROVIDERS=github
ENABLE_SCHEDULER=true

# For PostgreSQL production, generate a unique password and set both values.
# Never store the completed .env in Git.
# POSTGRES_PASSWORD=
# DATABASE_URL=postgresql://repowrangler:<password>@postgres:5432/repowrangler

# Real-mode application settings and credentials are target secrets, not plan
# fields. Ranch Hand writes them only during apply.
# PUBLIC_BASE_URL=https://wrangler.example.com
# ALLOWED_GITHUB_USERS=your-login
# SESSION_SECRET=
# SECRET_ENCRYPTION_KEY=
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
