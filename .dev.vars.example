# Copy to .dev.vars for local development. NEVER commit real values.
# Leave GitHub values empty and set DEMO_MODE=true to run with mock data.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=change-me-to-a-long-random-string
# Encrypts provider credentials entered through the first-run wizard.
SECRET_ENCRYPTION_KEY=change-me-to-another-long-random-string
# Optional protection for internet-facing first boot; leave empty for local setup.
SETUP_TOKEN=
PUBLIC_BASE_URL=http://localhost:8787
ALLOWED_GITHUB_USERS=
ALLOWED_GITHUB_ORGS=
DEMO_MODE=true
# Decoupled-frontend CORS (ADR-011, Mode B). Empty = integrated same-origin
# (Mode A). Comma-separated exact SPA origins, e.g.
# https://you.github.io,https://repo-wrangler.example.com
CORS_ALLOWED_ORIGINS=
# Microsoft Entra ID sign-in (set AUTH_MODE=entra) — leave empty for GitHub
AUTH_MODE=github_app
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_ALLOWED_USERS=
# GitLab (Phase 4) — leave empty to disable
GITLAB_TOKEN=
GITLAB_BASE_URL=https://gitlab.com
GITLAB_GROUPS=
GITLAB_WEBHOOK_SECRET=
# Outbound escalation webhook (Phase 5) — leave empty to disable
NOTIFY_WEBHOOK_URL=
