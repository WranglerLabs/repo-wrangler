# RepoWrangler Node server host — configuration.
#
# Copy to the repository root as `.env` (docker compose reads it there) and fill
# in real values for a live instance. Leave the GitHub values empty and keep
# DEMO_MODE=true to run on mock data with no secrets. NEVER commit real values.

# --- Host ---
PORT=8080
# SQLite database file. In Docker this defaults to /app/data/repo-wrangler.db
# (a named volume). Locally it defaults to ./data/repo-wrangler.db.
SQLITE_PATH=
# PostgreSQL connection string. Set this to use PostgreSQL instead of the
# embedded SQLite file — required for multiple API replicas sharing one database
# (Azure Container Apps, Kubernetes). Example:
#   postgres://repowrangler:PASSWORD@db-host:5432/repowrangler?sslmode=require
# Leave empty to use SQLite.
DATABASE_URL=
# Set to false to run the in-process scheduler on a single API replica only.
# With multiple replicas on PostgreSQL, enable it on exactly one replica.
ENABLE_SCHEDULER=true

# --- Scheduler driver (PN-3, ADR-018) ---
# in-process (default) = internal timer; external = no timer, an outside ticker
# POSTs /internal/cron/run; off = no scheduling.
SCHEDULER_MODE=in-process
# Shared bearer token authorizing POST /internal/cron/run when SCHEDULER_MODE=external.
# Example ticker: curl -fsS -X POST -H "authorization: Bearer $TOKEN" \
#   "$PUBLIC_BASE_URL/internal/cron/run?job=periodic"
CRON_TRIGGER_TOKEN=

# --- Secret source (PN-4, ADR-017) ---
# Where secrets are read from: env (default) | file | keyvault | composite.
# All non-env sources fall through to env for anything they don't provide.
SECRET_SOURCE=env
# file: directory of Docker/Kubernetes mounted secrets (one file per secret).
SECRETS_DIR=/run/secrets
# keyvault: Azure Key Vault URI, read with a managed identity (no static creds).
KEY_VAULT_URI=
# Optional user-assigned managed identity client id for the Key Vault adapter.
AZURE_CLIENT_ID=

# --- Mode ---
# Sign-in providers (PN-5, ADR-019): ordered CSV of github,gitlab,entra,google,local.
# When set, this supersedes AUTH_MODE; a provider appears only if also configured.
AUTH_PROVIDERS=
# Legacy single-provider selector, used only when AUTH_PROVIDERS is empty:
# github_app (default) or entra.
AUTH_MODE=github_app
# true = mock data, no secrets required. false = real GitHub App (fill in below).
DEMO_MODE=true
# Public URL of this instance (used in OAuth callbacks and links).
PUBLIC_BASE_URL=http://localhost:8080

# --- Access control ---
# Comma-separated GitHub logins allowed to sign in; the first to log in becomes
# the owner. Empty = demo only.
ALLOWED_GITHUB_USERS=
ALLOWED_GITHUB_ORGS=
DEFAULT_RETENTION_DAYS=

# --- GitHub App secrets (real mode) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Long random string that signs session cookies.
SESSION_SECRET=change-me-to-a-long-random-string

# --- Decoupled frontend (ADR-011, Mode B) ---
# Comma-separated exact SPA origins allowed to call the API cross-origin.
# Empty = integrated same-origin (the server serves the SPA itself).
CORS_ALLOWED_ORIGINS=

# --- Microsoft Entra ID sign-in (AUTH_MODE=entra) — leave empty for GitHub ---
# Register an app in Entra: Authentication → Web → redirect URI
# {PUBLIC_BASE_URL}/auth/entra/callback; grant delegated openid/profile/email.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Comma-separated sign-in names (UPN/email) allowed in; first becomes the owner.
ENTRA_ALLOWED_USERS=

# --- GitLab sign-in (AUTH_PROVIDERS includes gitlab) ---
# Register an OAuth application; redirect URI {PUBLIC_BASE_URL}/auth/gitlab/callback,
# scope read_user. Uses GITLAB_BASE_URL below (gitlab.com or self-managed).
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_ALLOWED_USERS=

# --- Google sign-in (AUTH_PROVIDERS includes google) ---
# OAuth 2.0 / OIDC client; redirect URI {PUBLIC_BASE_URL}/auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ALLOWED_USERS=

# --- Local-dev sign-in (AUTH_PROVIDERS includes local) — DEV ONLY ---
# Password-less; only active when 'local' is in AUTH_PROVIDERS AND this is set.
# Never enable in production. First user becomes the owner.
LOCAL_DEV_USERS=

# --- GitLab data provider (Phase 4) — leave empty to disable ---
GITLAB_TOKEN=
GITLAB_BASE_URL=https://gitlab.com
GITLAB_GROUPS=
GITLAB_WEBHOOK_SECRET=

# --- Outbound escalation webhook (Phase 5) — leave empty to disable ---
NOTIFY_WEBHOOK_URL=
