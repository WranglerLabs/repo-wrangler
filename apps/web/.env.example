# SPA build-time config (ADR-011). Copy to .env for a decoupled-frontend build.
# Leave BOTH empty for the default integrated Cloudflare Worker (Mode A).

# API origin the SPA calls. Empty = same-origin. Set to your Worker URL for Mode B,
# e.g. https://repo-wrangler.<subdomain>.workers.dev
VITE_API_BASE_URL=

# Host base path. "/" (default) for root hosting; "/repo-wrangler/" for a
# GitHub Pages project site.
VITE_BASE_PATH=

# Default theme id — must match a file src/themes/<id>.css (light, dark, midnight,
# slate, sandstone, high-contrast, or your own). Empty = follow the OS light/dark
# preference. Users can still switch themes in the UI (saved per browser).
VITE_DEFAULT_THEME=
